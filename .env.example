# Prisma — pooled connection for serverless runtime
DATABASE_URL="postgresql://user:password@host/dbname?channel_binding=require&sslmode=require"

# Prisma — direct connection for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Required only when intentionally running destructive local DB commands
ROLLORIAN_DB_CONTEXT="local-dev"
ROLLORIAN_ALLOW_DESTRUCTIVE_DB_ACTIONS="false"

# Google Books API
GOOGLE_BOOKS_API_KEY=""
