# Prisma — pooled connection for serverless runtime
DATABASE_URL="postgresql://user:password@host/dbname?channel_binding=require&sslmode=require"

# Prisma — direct connection for migrations
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Required only when intentionally running destructive local DB commands
ROLLORIAN_DB_CONTEXT="local-dev"
ROLLORIAN_ALLOW_DESTRUCTIVE_DB_ACTIONS="false"

# Google Books API
GOOGLE_BOOKS_API_KEY=""

# Auth.js v5 — secret used to sign/encrypt session tokens (generate with: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth credentials (from Google Cloud Console)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Auth.js canonical URL — required in production (e.g. https://yourdomain.com)
NEXTAUTH_URL=""

# Email address that is granted SUPERADMIN role on first sign-in
SUPERADMIN_EMAIL=""

# Resend (email)
RESEND_API_KEY=""

# Internal API for Donna
INTERNAL_API_KEY=""
DONNA_USER_EMAIL=""
